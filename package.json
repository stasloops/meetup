{
  "name": "meetup-frontend",
  "version": "1.0.0",
  "author": "GoMeetup Team",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/gomeetup/meetup-frontend"
  },
  "packageManager": "yarn@1.22.19",
  "scripts": {
    "build": "next build",
    "build:docker": "export IMAGE=gomeetupru/meetup-frontend:$(git branch --show-current) && docker build -t $IMAGE . && docker push $IMAGE",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "start": "next start",
    "start:dev": "next dev -p 4000"
  },
  "dependencies": {
    "@pbe/react-yandex-maps": "1.2.5",
    "dayjs": "1.11.10",
    "htmlparser2": "8.0.2",
    "inter-ui": "3.19.3",
    "js-cookie": "3.0.5",
    "log-timestamp": "0.3.0",
    "mobx": "6.12.0",
    "mobx-react-lite": "4.0.5",
    "next": "12.3.4",
    "next-svgr": "^0.0.2",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-google-recaptcha": "3.1.0",
    "react-hook-form": "7.47.0",
    "react-infinite-scroll-component": "6.1.0",
    "react-modal": "3.16.1",
    "react-scroll-up": "1.4.0",
    "react-select": "5.8.0",
    "rxjs": "7.8.1",
    "styled-components": "5.3.11",
    "styled-theming": "2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "babel-plugin-styled-components": "^2.1.4",
    "eslint": "^8.55.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-next": "12.3.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-webpack": "^0.13.8",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.1",
    "typescript": "5.3.3"
  }
